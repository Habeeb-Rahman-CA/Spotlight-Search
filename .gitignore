# ──────────────────────────────────────────
# Qt / CMake C++ Project .gitignore
# ──────────────────────────────────────────

# ── Build directories ──────────────────────
build/
build-*/
out/
cmake-build-*/
.cmake/

# ── CMake generated files ──────────────────
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/
*.cmake
!CMakeLists.txt

# ── Qt Creator project files ───────────────
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.creator.user
*.creator.user.*
.qmake.stash
.qmake.cache

# ── Compiled output ────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# ── Qt generated files ─────────────────────
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.moc

# ── QML cache ──────────────────────────────
*.qmlc
*.jsc
qmlcache/

# ── Windows specific ───────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Visual Studio ──────────────────────────
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates

# ── CLion / JetBrains ──────────────────────
.idea/
*.iml

# ── VS Code ────────────────────────────────
.vscode/

# ── Logs & temp ────────────────────────────
*.log
*.tmp
*.bak
*.swp
*~
